<!--submit CA Update Creds -->
<script>

      function submitCAUpdateCreds() {
        const caPrimeUrl = document.getElementById("caPrimeUrl").value.trim();
        const caStagingUrl = document.getElementById("caStagingUrl").value.trim();

        const data = {
            caPrimeUrl: caPrimeUrl,
            caStagingUrl: caStagingUrl
        };

        fetch('/Settings?handler=UpdateCAUrl', {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify(data)
        })
        .then(resp => resp.json())
        .then(result => {
            if (result.success) {
                showToast(result.message || "CA URLs updated!", false);
            } else {
                showToast(result.message || "Something went wrong updating CA URLs.", true);
            }
        })
        .catch(err => {
            showToast("Failed to update: " + err, true);
        });
    }

    function submitCertSettings() {
        const certValidityDays = parseInt(document.getElementById("certValidityDaysInput").value, 10);
        const renewBeforeExpiryDays = parseInt(document.getElementById("renewBeforeExpiryDaysInput").value, 10);

        if (!certValidityDays || certValidityDays < 1) {
            showToast("Cert validity days must be at least 1.", true);
            return;
        }
        if (!renewBeforeExpiryDays || renewBeforeExpiryDays < 1) {
            showToast("Renew before expiry days must be at least 1.", true);
            return;
        }

        fetch('/Settings?handler=UpdateCertSettings', {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ certValidityDays, renewBeforeExpiryDays })
        })
        .then(resp => resp.json())
        .then(result => {
            if (result.success) {
                showToast("Certificate settings updated!", false);
            } else {
                showToast(result.message || "Failed to update certificate settings.", true);
            }
        })
        .catch(err => {
            showToast("Failed to update: " + err, true);
        });
    }

    // --- Mode Settings ---
    function saveModeSettings() {
        fetch('/Settings?handler=UpdateModeSettings', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                stagingOnly: document.getElementById('stagingOnlySwitch').checked,
                restrictViewers: document.getElementById('restrictViewersSwitch').checked,
                hideViewerLogout: document.getElementById('hideViewerLogoutSwitch').checked
            })
        })
        .then(r => r.ok ? r.json() : Promise.reject('HTTP ' + r.status))
        .then(d => showToast(d.message || (d.success ? 'Saved.' : 'Save failed.'), !d.success))
        .catch(e => showToast('Failed to save: ' + e, true));
    }

    function saveDemoLogin() {
        const enabled = document.getElementById('demoLoginEnabledSwitch').checked;
        const username = document.getElementById('demoUsernameInput').value.trim();
        const password = document.getElementById('demoPasswordInput').value;

        if (enabled && (!username || !password)) {
            showToast('Demo username and password are required when Demo Login is enabled.', true);
            return;
        }

        fetch('/Settings?handler=UpdateModeSettings', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                demoLoginEnabled: enabled,
                demoUsername: username,
                demoPassword: password
            })
        })
        .then(r => r.ok ? r.json() : Promise.reject('HTTP ' + r.status))
        .then(d => showToast(d.message || (d.success ? 'Saved.' : 'Save failed.'), !d.success))
        .catch(e => showToast('Failed to save: ' + e, true));
    }

    // --- Connect Tab ---
    const connectionSettingsTemplates = {
        Discord:  `<div class="mb-3"><label class="form-label">Webhook URL</label><input class="form-control" id="cs_webhookUrl" placeholder="https://discord.com/api/webhooks/..."></div>`,
        Slack:    `<div class="mb-3"><label class="form-label">Webhook URL</label><input class="form-control" id="cs_webhookUrl" placeholder="https://hooks.slack.com/services/..."></div>`,
        Webhook:  `<div class="mb-3"><label class="form-label">URL</label><input class="form-control" id="cs_url"></div>
                   <div class="mb-3"><label class="form-label">Method</label><select class="form-select" id="cs_method"><option>POST</option><option>GET</option></select></div>
                   <div class="mb-3"><label class="form-label">Body template (use {message})</label><input class="form-control" id="cs_body" placeholder='{"text":"{message}"}'></div>`,
        ntfy:     `<div class="mb-3"><label class="form-label">Topic URL</label><input class="form-control" id="cs_url" placeholder="https://ntfy.sh/mytopic"></div>`,
        Gotify:   `<div class="mb-3"><label class="form-label">Server URL</label><input class="form-control" id="cs_url" placeholder="https://gotify.example.com"></div>
                   <div class="mb-3"><label class="form-label">App Token</label><input class="form-control" id="cs_token"></div>`,
        Telegram: `<div class="mb-3"><label class="form-label">Bot Token</label><input class="form-control" id="cs_botToken"></div>
                   <div class="mb-3"><label class="form-label">Chat ID</label><input class="form-control" id="cs_chatId"></div>`,
        Email:    `<div class="mb-3"><label class="form-label">SMTP Host</label><input class="form-control" id="cs_host"></div>
                   <div class="row g-2 mb-3"><div class="col-4"><label class="form-label">Port</label><input class="form-control" type="number" id="cs_port" value="587"></div><div class="col-8"><label class="form-label">Username</label><input class="form-control" id="cs_username"></div></div>
                   <div class="mb-3"><label class="form-label">Password</label><input class="form-control" type="password" id="cs_password"></div>
                   <div class="row g-2 mb-3"><div class="col-6"><label class="form-label">From</label><input class="form-control" id="cs_from"></div><div class="col-6"><label class="form-label">To</label><input class="form-control" id="cs_to"></div></div>`,
        Script:   `<div class="mb-3"><label class="form-label">Script path or command</label><input class="form-control" id="cs_script" placeholder="/opt/scripts/notify.sh"></div>`
    };

    const connectionSettingsFields = {
        Discord: ['webhookUrl'], Slack: ['webhookUrl'],
        Webhook: ['url', 'method', 'body'], ntfy: ['url'],
        Gotify: ['url', 'token'], Telegram: ['botToken', 'chatId'],
        Email: ['host', 'port', 'username', 'password', 'from', 'to'], Script: ['script']
    };

    function openTypePickerModal() {
        new bootstrap.Modal(document.getElementById('typePickerModal')).show();
    }

    function openConnectionModal(type, existingData) {
        document.getElementById('connType').value = type;
        document.getElementById('connectionConfigTitle').textContent = (existingData ? 'Edit' : 'Add') + ' ' + type + ' Connection';
        document.getElementById('connSettingsFields').innerHTML = connectionSettingsTemplates[type] || '';
        document.getElementById('connEditId').value = existingData?.connectionId ?? '';
        document.getElementById('connName').value = existingData?.connectionName ?? '';
        document.getElementById('connIsEnabled').checked = existingData ? existingData.isEnabled : true;
        document.getElementById('connOnPreRenew').checked = existingData ? existingData.onPreRenew : true;
        document.getElementById('connOnPreExpiry').checked = existingData ? existingData.onPreExpiry : true;
        document.getElementById('connOnRenewSuccess').checked = existingData ? existingData.onRenewSuccess : true;
        document.getElementById('connOnRenewFail').checked = existingData ? existingData.onRenewFail : true;

        if (existingData?.settings) {
            try {
                const s = typeof existingData.settings === 'string' ? JSON.parse(existingData.settings) : existingData.settings;
                Object.entries(s).forEach(([k, v]) => {
                    const el = document.getElementById('cs_' + k);
                    if (el) el.value = v;
                });
            } catch (e) {}
        }
        new bootstrap.Modal(document.getElementById('connectionConfigModal')).show();
    }

    function buildSettingsJson(type) {
        const result = {};
        (connectionSettingsFields[type] || []).forEach(f => {
            const el = document.getElementById('cs_' + f);
            if (el) result[f] = el.value;
        });
        return result;
    }

    function buildConnectionPayload() {
        const type = document.getElementById('connType').value;
        return {
            connectionId:   document.getElementById('connEditId').value,
            connectionName: document.getElementById('connName').value.trim(),
            connectionType: type,
            isEnabled:      document.getElementById('connIsEnabled').checked,
            onPreRenew:     document.getElementById('connOnPreRenew').checked,
            onPreExpiry:    document.getElementById('connOnPreExpiry').checked,
            onRenewSuccess: document.getElementById('connOnRenewSuccess').checked,
            onRenewFail:    document.getElementById('connOnRenewFail').checked,
            settings:       buildSettingsJson(type)
        };
    }

    function saveConnection() {
        const payload = buildConnectionPayload();
        if (!payload.connectionName) { showToast("Please enter a connection name.", true); return; }
        const isEdit = !!payload.connectionId;
        fetch(`/Settings?handler=${isEdit ? 'UpdateConnection' : 'AddConnection'}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        })
        .then(r => r.json())
        .then(d => {
            if (d.success) {
                const modal = bootstrap.Modal.getInstance(document.getElementById('connectionConfigModal'));
                if (modal) modal.hide();
                showToast(d.message, false);
                setTimeout(() => location.reload(), 800);
            } else {
                showToast(d.message || 'Failed to save connection.', true);
            }
        })
        .catch(e => showToast('Request failed: ' + e, true));
    }

    function editConnection(connectionId) {
        fetch(`/Settings?handler=GetConnection&connectionId=${encodeURIComponent(connectionId)}`)
        .then(r => r.json())
        .then(d => {
            if (d.success) openConnectionModal(d.connection.connectionType, d.connection);
            else showToast('Could not load connection.', true);
        })
        .catch(e => showToast('Request failed: ' + e, true));
    }

    function deleteConnection(connectionId, name) {
        if (!confirm(`Delete connection "${name}"?`)) return;
        fetch('/Settings?handler=DeleteConnection', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ connectionId })
        })
        .then(r => r.json())
        .then(d => {
            showToast(d.message, !d.success);
            if (d.success) {
                const row = document.querySelector(`tr[data-connection-id="${connectionId}"]`);
                if (row) row.remove();
            }
        })
        .catch(e => showToast('Request failed: ' + e, true));
    }

    function testConnection() {
        const payload = buildConnectionPayload();
        fetch('/Settings?handler=TestConnection', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        })
        .then(r => r.json())
        .then(d => showToast(d.message, !d.success))
        .catch(e => showToast('Test failed: ' + e, true));
    }
</script>


